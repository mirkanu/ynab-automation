generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Setting {
  id        String   @id @default(cuid())
  userId    String
  key       String
  value     String
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

model ProcessedEmail {
  id          Int      @id @default(autoincrement())
  userId      String
  messageId   String
  sender      String
  processedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId])
  @@index([userId, processedAt])
}

model ActivityLog {
  id           Int      @id @default(autoincrement())
  userId       String
  messageId    String   @unique
  status       String

  // Inbound email metadata (LOG-01)
  sender       String?
  subject      String?
  receivedAt   DateTime @default(now())
  rawBody      String?

  // Claude parse result (LOG-02)
  parseResult  Json?

  // YNAB outcome (LOG-03)
  ynabResult   Json?

  // Error detail (LOG-04)
  errorType    String?
  errorMessage String?

  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?

  // Prepared for Phase 17 (YNAB OAuth tokens — encrypted at rest)
  oauthToken        String?
  oauthRefreshToken String?
  oauthExpiresAt    BigInt?

  // Phase 17: token management fields
  lastRefreshAttemptAt  DateTime?  // Mutex: prevents concurrent refresh token exhaustion
  selectedBudgetId      String?    // Phase 17 YNAB-05: user's chosen default budget
  selectedAccountId     String?    // Phase 17 YNAB-05: user's chosen default account

  // Prepared for Phase 18 (unique forwarding email per user)
  forwardingEmail String? @unique

  accounts                 Account[]
  sessions                 Session[]
  activityLogs             ActivityLog[]
  settings                 Setting[]
  processedEmails          ProcessedEmail[]
  emailForwardingAddresses EmailForwardingAddress[]
  processedWebhooks        ProcessedWebhook[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailForwardingAddress {
  id          String   @id @default(cuid())
  userId      String
  mailboxHash String   @unique
  email       String

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([userId, mailboxHash])
  @@index([userId])
}

model ProcessedWebhook {
  id         Int      @id @default(autoincrement())
  provider   String   // "postmark"
  providerId String   // MessageID from provider (unique per delivery)
  userId     String
  status     String   @default("success")  // "success", "error", "skipped"

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())

  @@unique([provider, providerId])
  @@index([userId, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
