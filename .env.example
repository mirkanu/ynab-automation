# Database (auto-set by Railway PostgreSQL add-on)
DATABASE_URL=

# Claude API (Anthropic)
ANTHROPIC_API_KEY=

# YNAB
YNAB_PERSONAL_ACCESS_TOKEN=
YNAB_BUDGET_ID=

# Sender routing — JSON array, see config.example.json for format
SENDERS=

# Currency account overrides — JSON object, optional (e.g. {"EUR":"ynab-account-uuid"})
# Omit if you only use one currency.
CURRENCY_ACCOUNTS=

# Error notifications
ADMIN_EMAIL=
RESEND_API_KEY=

# Admin Authentication (Phase 11)
# Generate IRON_SESSION_SECRET with: openssl rand -base64 32
# The value must be at least 32 characters long.
IRON_SESSION_SECRET=your-32-plus-character-secret-here
ADMIN_PASSWORD=your-admin-password-here

# Inbound email address (optional, displayed on admin dashboard)
# e.g. your Pipedream inbound email address
INBOUND_EMAIL=

# Postmark inbound email domain (used for per-user forwarding addresses — EMAIL-01)
# Defaults to inbound.postmarkapp.com if not set
POSTMARK_INBOUND_DOMAIN=inbound.postmarkapp.com

# Postmark inbound webhook IP allowlist (EMAIL-03 security — reject requests not from Postmark)
# Comma-separated list of Postmark inbound server IPs.
# See: https://postmarkapp.com/developer/user-guide/inbound/parse-an-email
POSTMARK_IPS=3.134.147.250,50.31.156.6,50.31.156.77,18.217.206.57

# Auth.js
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
EMAIL_FROM=noreply@yourdomain.com
