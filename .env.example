# Database (auto-set by Railway PostgreSQL add-on)
DATABASE_URL=

# Claude API (Anthropic)
ANTHROPIC_API_KEY=

# YNAB
YNAB_PERSONAL_ACCESS_TOKEN=
YNAB_BUDGET_ID=

# Sender routing — JSON array, see config.example.json for format
SENDERS=

# Currency account overrides — JSON object, optional (e.g. {"EUR":"ynab-account-uuid"})
# Omit if you only use one currency.
CURRENCY_ACCOUNTS=

# Error notifications
ADMIN_EMAIL=
RESEND_API_KEY=
